# --- Python & Virtual Environment ---
# Prevents uploading the massive folder holding your installed libraries
venv/
env/
.env

# --- Auto-generated Python Cache ---
# These are compiled files Python makes automatically to run faster
__pycache__/
*.py[cod]
*$py.class

# --- Project Specific Data ---
# Ignores your target folder so you don't leak raw government election data
data/

# Ignores any rogue Excel or CSV files lying around in the main folder
*.xlsx
*.xls
*.csv

# --- Streamlit ---
# Ignores Streamlit's local configuration and cache files
.streamlit/

# --- OS Specific ---
# Ignores hidden system files generated by Windows or Mac
.DS_Store
Thumbs.db